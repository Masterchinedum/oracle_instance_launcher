# Copy this file to ".env" and fill in your real values.
# ".env" is gitignored and must NEVER be committed.

# --- From the OCI "Add API key" config preview (Step 2) ---
OCI_USER_OCID=ocid1.user.oc1..xxxx
OCI_TENANCY_OCID=ocid1.tenancy.oc1..xxxx
OCI_FINGERPRINT=aa:bb:cc:dd:ee:ff:...
OCI_REGION=eu-frankfurt-1

# Path to the private key generated locally (Step 1).
OCI_PRIVATE_KEY_PATH=~/.oci/oci_api_key.pem

# --- Gathered from the console (Step 3) ---
OCI_COMPARTMENT_OCID=ocid1.compartment.oc1..xxxx   # or your tenancy OCID
OCI_AVAILABILITY_DOMAIN=abcd:EU-FRANKFURT-1-AD-1
OCI_SUBNET_OCID=ocid1.subnet.oc1.eu-frankfurt-1.xxxx
OCI_IMAGE_OCID=ocid1.image.oc1.eu-frankfurt-1.xxxx   # must be aarch64/ARM

# Your SSH public key (so you can log into the instance once it launches).
OCI_SSH_PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub

# --- Instance config ---
OCI_INSTANCE_DISPLAY_NAME=free-tier-a1
OCI_BOOT_VOLUME_GB=100
OCI_SHAPE_LADDER="4,24; 4,12; 2,12; 2,6; 1,6"

# --- Email notification (Gmail SMTP) ---
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=your16charapppassword
NOTIFY_EMAIL=chinedu02k@gmail.com
